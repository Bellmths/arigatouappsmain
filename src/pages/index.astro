---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import AppCard from "../components/AppCard.astro";
import FeaturedApp from "../components/FeaturedApp.astro";
import Faq from "../components/Faq.astro";
import { site } from "../data/site";
import { services } from "../data/services";
import { apps, developerUrl } from "../data/apps";
import { homeJsonLd } from "../lib/structuredData";

const featured = apps.find((a) => a.featured);
const rest = apps.filter((a) => !a.featured);
const accents = ["pink", "mint", "green", "blue", "cyan", "purple", "yellow", "lime"];
---

<BaseLayout jsonLd={homeJsonLd}>
  <!-- Hero -->
  <section id="top" class="hero">
    <div class="wrap">
      <span class="eyebrow">arigatouapps · personal studio</span>
      <h1 class="hero__title display">{site.name}</h1>
      <p class="hero__tagline">{site.tagline}</p>
      <p class="hero__desc">{site.description}</p>
      <div class="hero__cta">
        <a href="#projects" class="btn btn--solid">作ったものを見る</a>
        <a href="#apps" class="btn">アプリ一覧</a>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="section">
    <div class="wrap">
      <div class="section__head">
        <span class="eyebrow">projects</span>
        <h2 class="section__title">つくっているもの</h2>
      </div>
      <div class="grid grid--3">
        {services.map((s) => <ServiceCard service={s} />)}
        <a href="#apps" class="proj-android" style="--accent:var(--c-lime)">
          <span class="proj-android__swatch"></span>
          <div class="proj-android__top">
            <span class="eyebrow">project</span>
            <span class="tag">{apps.length}+ apps</span>
          </div>
          <h3 class="proj-android__title">Android アプリ</h3>
          <p class="proj-android__desc">
            TimeAware / WatchLog / QR Widget など、日常を少し便利にする小品。
          </p>
          <span class="proj-android__cta">下の一覧へ ↓</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Apps -->
  <section id="apps" class="section section--alt">
    <div class="wrap">
      <div class="section__head apps__head">
        <div>
          <span class="eyebrow">apps · android</span>
          <h2 class="section__title">Android アプリ</h2>
        </div>
        <span class="eyebrow">{apps.length} on google play</span>
      </div>

      {featured && <FeaturedApp app={featured} />}

      <div class="grid apps__grid">
        {rest.map((a, i) => <AppCard app={a} accent={accents[i % accents.length]} />)}
      </div>

      <p class="apps__more">
        <a href={developerUrl} target="_blank" rel="noopener">
          Google Play の開発者ページで見る →
        </a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="section">
    <div class="wrap">
      <div class="section__head">
        <span class="eyebrow">faq</span>
        <h2 class="section__title">よくある質問</h2>
      </div>
      <Faq />
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section section--alt">
    <div class="wrap about">
      <div>
        <span class="eyebrow">about</span>
        <h2 class="section__title">ArigatouApps について</h2>
      </div>
      <div class="about__body">
        <p>
          個人の趣味で Android アプリと web ツールを作っています。
          「小さく作って、ちゃんと届ける」をモットーに、日常を少し便利にする小品を公開しています。
          自作キーボードについてのブログも準備中です。
        </p>
        <div class="about__links">
          <a class="btn btn--solid" href={`mailto:${site.email}`}>お問い合わせ</a>
          <a class="btn" href={developerUrl} target="_blank" rel="noopener">Google Play</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: clamp(56px, 11vw, 120px) 0 clamp(40px, 7vw, 80px); }
  .hero__title { font-size: clamp(52px, 11vw, 120px); margin: 12px 0 0; }
  .hero__tagline { font-size: clamp(20px, 3vw, 28px); margin: 18px 0 0; font-weight: 500; }
  .hero__desc { color: var(--soft); max-width: 560px; margin: 12px 0 0; }
  .hero__cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }

  .section--alt { background: var(--card); border-top: var(--border); border-bottom: var(--border); }

  .grid--3 { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }

  .apps__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .apps__grid { margin-top: 22px; }
  .apps__more { margin-top: 22px; text-align: right; }
  .apps__more a { font-family: var(--font-mono); font-size: 0.82rem; }
  .apps__more a:hover { text-decoration: underline; }

  /* Android プロジェクトカード（services と同じ見た目だが下へスクロール） */
  .proj-android {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 22px;
    background: var(--card);
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.12s, box-shadow 0.12s;
  }
  .proj-android:hover { transform: translate(-3px, -3px); box-shadow: 6px 6px 0 var(--ink); }
  .proj-android__swatch { height: 64px; margin: -22px -22px 6px; background: var(--accent); border-bottom: var(--border); }
  .proj-android__top { display: flex; align-items: center; justify-content: space-between; }
  .proj-android__title { font-size: 21px; font-weight: 700; letter-spacing: -0.01em; margin: 2px 0 0; }
  .proj-android__desc { color: var(--soft); font-size: 0.92rem; flex: 1; }
  .proj-android__cta { font-family: var(--font-mono); font-size: 0.8rem; }

  .about { display: grid; grid-template-columns: 1fr 1.4fr; gap: 28px; align-items: start; }
  .about__body p { color: var(--soft); }
  .about__links { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 20px; }
  @media (max-width: 720px) {
    .about { grid-template-columns: 1fr; }
  }
</style>
