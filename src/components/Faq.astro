---
import { faq } from "../data/faq";
---
<div class="faq">
  {faq.map((item) => (
    <details class="faq__item">
      <summary class="faq__q">{item.q}</summary>
      <p class="faq__a">{item.a}</p>
    </details>
  ))}
</div>

<style>
  .faq { display: grid; gap: 10px; }
  .faq__item {
    background: var(--card);
    border: var(--border);
    border-radius: 14px;
    padding: 2px 20px;
  }
  .faq__q {
    cursor: pointer;
    font-weight: 700;
    padding: 16px 0;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::after {
    content: "+";
    font-family: var(--font-mono);
    color: var(--soft);
    font-size: 1.3rem;
    transition: transform 0.15s;
  }
  .faq__item[open] .faq__q::after { transform: rotate(45deg); }
  .faq__a {
    margin: 0 0 16px;
    color: var(--soft);
    font-size: 0.92rem;
  }
</style>
