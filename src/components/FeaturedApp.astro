---
import type { AndroidAppWithUrl } from "../data/apps";
interface Props {
  app: AndroidAppWithUrl;
}
const { app } = Astro.props;
---
<div class="feat">
  <div class="feat__body">
    <span class="eyebrow">★ featured · android</span>
    <h3 class="feat__name display">{app.name}</h3>
    <p class="feat__desc">{app.desc}</p>
    {app.features && (
      <ul class="feat__list">
        {app.features.map((f) => <li>{f}</li>)}
      </ul>
    )}
    <a class="feat__badge" href={app.playUrl} target="_blank" rel="noopener"
      aria-label={`${app.name} を Google Play で入手`}>
      <img
        src="https://play.google.com/intl/ja/badges/static/images/badges/ja_badge_web_generic.png"
        alt="Google Play で手に入れよう"
        height="56"
        loading="lazy"
      />
    </a>
  </div>
  <div class="feat__art" aria-hidden="true">
    <span>{app.emoji ?? "📱"}</span>
  </div>
</div>

<style>
  .feat {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 0;
    background: var(--card);
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .feat__body { padding: clamp(24px, 4vw, 40px); }
  .feat__name { font-size: clamp(34px, 5vw, 52px); margin: 10px 0 12px; }
  .feat__desc { color: var(--soft); max-width: 46ch; }
  .feat__list {
    list-style: none;
    margin: 18px 0 24px;
    display: grid;
    gap: 10px;
  }
  .feat__list li {
    position: relative;
    padding-left: 26px;
    font-size: 0.92rem;
  }
  .feat__list li::before {
    content: "→";
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    color: var(--soft);
  }
  .feat__badge {
    display: inline-block;
    /* 公式バッジは透明の余白を含むため、左の視覚位置を合わせる */
    margin-left: -10px;
    transition: transform 0.12s;
  }
  .feat__badge:hover { transform: translateY(-2px); }
  .feat__badge img { height: 56px; width: auto; }
  .feat__art {
    border-left: var(--border);
    background: var(--c-cyan);
    display: grid;
    place-items: center;
    font-size: clamp(60px, 12vw, 120px);
  }
  @media (max-width: 720px) {
    .feat { grid-template-columns: 1fr; }
    .feat__art { border-left: none; border-top: var(--border); min-height: 160px; }
  }
</style>
